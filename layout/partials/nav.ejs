<nav class="main-nav" aria-label="Main navigation">
  <div class="container-wide nav-inner">
    <% theme.navigation.forEach((item) => { %>
      <a href="<%= item.path %>" class="<%= url_for(page.path || '/') === item.path ? 'is-active' : '' %>"><%= shit_link_label(item) %></a>
    <% }) %>
    <div class="nav-actions">
      <button class="nav-icon-button nav-search-trigger" type="button" data-search-open="true" aria-haspopup="dialog" aria-controls="site-search-dialog" aria-label="<%= shit_ui('search') %>">
        <i class="fa-solid fa-magnifying-glass" aria-hidden="true"></i>
        <span class="sr-only"><%= shit_ui('search') %></span>
      </button>
      <button class="nav-icon-button nav-theme-toggle" type="button" data-color-mode-toggle="true" aria-label="<%= shit_ui('toggle_theme') %>">
        <i class="fa-solid fa-circle-half-stroke" aria-hidden="true"></i>
        <span class="sr-only"><%= shit_ui('toggle_theme') %></span>
      </button>
    </div>
  </div>
</nav>
